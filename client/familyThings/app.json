{
  "expo": {
    "name": "Family Things",
    "slug": "family-things",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "familythings",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familythings.mobile"
    },
    "android": {
      "package": "com.familythings.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#FFF7EF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
